# ========================================
# VARIABLES DE ENTORNO
# Copia este archivo como `.env` y rellena
# los valores reales. El archivo `.env`
# nunca debe subirse al repositorio.
# ========================================

# --- BitLocker (Windows) ---
# Clave de recuperación de BitLocker para montar la partición de Windows
# Formato: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX-XXXXX
BITLOCKER_KEY=""

# Dispositivo de la partición de Windows (ajusta si es distinto en tu equipo)
BITLOCKER_DEVICE="/dev/nvme0n1p3"

# Punto de montaje
BITLOCKER_MOUNT="/mnt/win"
