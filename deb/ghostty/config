# Fuente como tu rofi
# font-family = "Iosevka Nerd Font"
font-family = "Cascadia Code"
font-feature = calt, liga, dlig, clig, ss01, ss02, ss03, ss04, ss05, ss06, ss07, ss08, ss09, ss10, ss11, ss12, ss13, ss14, ss15, ss16, ss17, ss18, ss19, ss20
font-size = 10
term = xterm-256color

# Usar el theme que acabas de crear (por nombre de archivo)
theme = rofi-adi1090x

# “transparency: real” estilo rofi (ajusta a gusto)
background-opacity = 0.92
background-blur = 20

# Look más “plano” (sin bordes/decoración)
window-decoration = none

# Un poco de aire (rofi tiene padding generoso)
window-padding-x = 10
window-padding-y = 10

# Opcional: que el chrome de la ventana use tus colores (Linux)
window-theme = ghostty

# Keybindings personalizados (ejemplo: Ctrl+Shift+F para buscar)
keybind = ctrl+shift+f=start_search

# Ctrl+C: copia SOLO si hay selección; si no hay selección, se comporta normal (SIGINT)
keybind = performable:ctrl+c=copy_to_clipboard

# Ctrl+V: pegar desde clipboard
keybind = ctrl+v=paste_from_clipboard

# Ctrl+Backspace: borrar palabra hacia la izquierda (manda ESC DEL)
keybind = ctrl+backspace=text:\x1b\x7f

# Ctrl+Delete: borrar palabra hacia la derecha (manda ESC d)
keybind = ctrl+delete=esc:d

keybind = ctrl+left=esc:b
keybind = ctrl+right=esc:f

# Velocidad de scroll (default=1.0, aumentar para más rápido)
mouse-scroll-multiplier = 5
