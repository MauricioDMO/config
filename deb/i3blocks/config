separator=true
separator_block_width=12
markup=pango

[wireless]
command=~/.config/i3blocks/scripts/wifi.sh
interval=5

[ethernet]
command=~/.config/i3blocks/scripts/ethernet.sh
interval=5

[phonebattery]
command=~/.config/i3blocks/scripts/adb-battery.sh
interval=10

[battery]
command=~/.config/i3blocks/scripts/battery.sh
interval=10

[cpu_temp]
command=~/.config/i3blocks/scripts/cpu_temp.sh /sys/class/thermal/thermal_zone5/temp
interval=5

[memory]
command=~/.config/i3blocks/scripts/memory.sh
interval=5

[volume]
command=~/.config/i3blocks/scripts/volume.sh
interval=1

[time]
command=~/.config/i3blocks/scripts/datetime.sh
interval=1
